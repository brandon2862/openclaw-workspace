{
  "name": "electron-vue-app",
  "version": "1.0.0",
  "description": "A modern Windows desktop application example with Electron + Vue.js 3 + TypeScript",
  "main": "out/main/index.js",
  "author": "Brandon Wong",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "npm run build:main && electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build",
    "watch:main": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "watch:renderer": "vite build --watch",
    "lint": "eslint . --ext .ts,.tsx,.vue,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.vue,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,vue,json,md}\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "element-plus": "^2.4.4",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.19.2",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vue-tsc": "^1.8.25"
  },
  "build": {
    "appId": "com.example.electronvueapp",
    "productName": "Electron Vue App",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "your-username",
        "repo": "electron-vue-app"
      }
    ]
  }
}