                                        </tr>
                                    </tbody>
                                </table>
                                <div v-else class="empty-state">
                                    <i class="fas fa-users"></i>
                                    <p>暂无客户数据</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 客户管理页面 -->
                    <div v-if="currentPage === 'customers'">
                        <h1 class="card-title">
                            <i class="fas fa-users"></i> 客户管理
                        </h1>
                        
                        <!-- 搜索和操作栏 -->
                        <div class="card" style="margin-bottom: 20px;">
                            <div style="display: flex; gap: 12px; align-items: center;">
                                <div style="flex: 1;">
                                    <input type="text" class="form-control" v-model="customerSearch" placeholder="搜索客户名称、Marking、电话..." @input="searchCustomers">
                                </div>
                                <button class="btn btn-primary" @click="showAddCustomer = true" v-if="user.role === 'ADMIN'">
                                    <i class="fas fa-plus"></i> 新增客户
                                </button>
                            </div>
                        </div>
                        
                        <!-- 客户列表 -->
                        <div class="card">
                            <div class="table-container">
                                <table v-if="customers.length > 0">
                                    <thead>
                                        <tr>
                                            <th>客户名称</th>
                                            <th>Marking</th>
                                            <th>默认货币对</th>
                                            <th>接收人</th>
                                            <th>电话</th>
                                            <th>银行</th>
                                            <th v-if="user.role === 'ADMIN'">操作</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr v-for="customer in customers" :key="customer.id">
                                            <td>{{ customer.customer_name }}</td>
                                            <td>{{ customer.marking || '-' }}</td>
                                            <td>{{ customer.default_currency_pair }}</td>
                                            <td>{{ customer.recipient_name || '-' }}</td>
                                            <td>{{ customer.phone || '-' }}</td>
                                            <td>{{ customer.bank_name || '-' }}</td>
                                            <td v-if="user.role === 'ADMIN'">
                                                <button class="btn btn-primary" @click="editCustomer(customer)" style="margin-right: 8px;">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <button class="btn btn-danger" @click="deleteCustomer(customer.id)">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <div v-else class="empty-state">
                                    <i class="fas fa-users"></i>
                                    <p>暂无客户数据</p>
                                </div>
                            </div>
                            
                            <!-- 分页 -->
                            <div class="pagination" v-if="customerPagination.total > 0">
                                <button class="page-btn" @click="prevCustomerPage" :disabled="customerPagination.page === 1">
                                    <i class="fas fa-chevron-left"></i>
                                </button>
                                <span>第 {{ customerPagination.page }} 页 / 共 {{ customerPagination.pages }} 页</span>
                                <button class="page-btn" @click="nextCustomerPage" :disabled="customerPagination.page === customerPagination.pages">
                                    <i class="fas fa-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 新增交易页面 -->
                    <div v-if="currentPage === 'new-transaction'">
                        <h1 class="card-title">
                            <i class="fas fa-plus-circle"></i> 新增交易
                        </h1>
                        
                        <div class="card">
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                                <!-- 左侧：客户信息 -->
                                <div>
                                    <h3 style="margin-bottom: 20px; color: #409EFF; display: flex; align-items: center; gap: 8px;">
                                        <i class="fas fa-user-circle"></i> 客户信息
                                    </h3>
                                    
                                    <div class="form-group">
                                        <label class="form-label">选择客户 *</label>
                                        <select class="form-control" v-model="transactionForm.customer_id" @change="loadCustomerInfo">
                                            <option value="">请选择客户</option>
                                            <option v-for="customer in allCustomers" :key="customer.id" :value="customer.id">
                                                {{ customer.customer_name }} ({{ customer.marking || '无Marking' }})
                                            </option>
                                        </select>
                                    </div>
                                    
                                    <!-- 客户资料显示 -->
                                    <div v-if="selectedCustomer" style="background: #f8f9fa; padding: 20px; border-radius: 8px; margin-top: 20px;">
                                        <h4 style="margin-bottom: 15px; color: #606266;">客户资料</h4>
                                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                                            <div>
                                                <label style="font-size: 12px; color: #909399;">Marking</label>
                                                <div style="font-weight: 500;">{{ selectedCustomer.marking || '-' }}</div>
                                            </div>
                                            <div>
                                                <label style="font-size: 12px; color: #909399;">默认货币对</label>
                                                <div style="font-weight: 500;">{{ selectedCustomer.default_currency_pair }}</div>
                                            </div>
                                            <div>
                                                <label style="font-size: 12px; color: #909399;">接收人</label>
                                                <div style="font-weight: 500;">{{ selectedCustomer.recipient_name || '-' }}</div>
                                            </div>
                                            <div>
                                                <label style="font-size: 12px; color: #909399;">电话</label>
                                                <div style="font-weight: 500;">{{ selectedCustomer.phone || '-' }}</div>
                                            </div>
                                            <div style="grid-column: span 2;">
                                                <label style="font-size: 12px; color: #909399;">银行信息</label>
                                                <div style="font-weight: 500;">{{ selectedCustomer.bank_name || '-' }} {{ selectedCustomer.bank_account || '' }}</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- 右侧：交易信息 -->
                                <div>
                                    <h3 style="margin-bottom: 20px; color: #409EFF; display: flex; align-items: center; gap: 8px;">
                                        <i class="fas fa-exchange-alt"></i> 交易信息
                                    </h3>
                                    
                                    <div class="form-group">
                                        <label class="form-label">Agent SX Cost *</label>
                                        <input type="number" step="0.0001" class="form-control" v-model="transactionForm.agent_sx_cost" @input="calculateRates" placeholder="请输入Agent SX Cost">
                                    </div>
                                    
                                    <!-- 报价选项 -->
                                    <div style="margin-bottom: 20px;">
                                        <label class="form-label">选择报价选项</label>
                                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                                            <div class="option-card" :class="{ active: transactionForm.selected_option === 1 }" @click="selectOption(1)">
                                                <div style="font-weight: 600; color: #409EFF;">Option 1</div>
                                                <div style="font-size: 18px; font-weight: 700;">{{ calculatedRates.option1 || '0.0000' }}</div>
                                                <div style="font-size: 12px; color: #909399;">Agent SX Cost - 0.05</div>
                                            </div>
                                            <div class="option-card" :class="{ active: transactionForm.selected_option === 2 }" @click="selectOption(2)">
                                                <div style="font-weight: 600; color: #67C23A;">Option 2</div>
                                                <div style="font-size: 18px; font-weight: 700;">{{ calculatedRates.option2 || '0.0000' }}</div>
                                                <div style="font-size: 12px; color: #909399;">Agent SX Cost - 0.08</div>
                                            </div>
                                            <div class="option-card" :class="{ active: transactionForm.selected_option === 3 }" @click="selectOption(3)">
                                                <div style="font-weight: 600; color: #E6A23C;">Option 3</div>
                                                <div style="font-size: 18px; font-weight: 700;">{{ calculatedRates.option3 || '0.0000' }}</div>
                                                <div style="font-size: 12px; color: #909399;">Agent SX Cost - 0.10</div>
                                            </div>
                                            <div class="option-card" :class="{ active: transactionForm.selected_option === 4 }" @click="selectOption(4)">
                                                <div style="font-weight: 600; color: #8A2BE2;">Option 4</div>
                                                <div v-if="transactionForm.selected_option === 4">
                                                    <input type="number" step="0.0001" class="form-control" v-model="transactionForm.manual_rate" @input="updateManualRate" placeholder="手动输入汇率" style="margin-top: 8px;">
                                                </div>
                                                <div v-else style="font-size: 18px; font-weight: 700;">手动输入</div>
                                                <div style="font-size: 12px; color: #909399;">自定义汇率</div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label class="form-label">源金额 (RMB) *</label>
                                        <input type="number" step="0.01" class="form-control" v-model="transactionForm.source_amount" @input="calculateAmount" placeholder="请输入RMB金额">
                                    </div>
                                    
                                    <!-- 计算结果 -->
                                    <div style="background: #f0f9eb; padding: 20px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #c2e7b0;">
                                        <h4 style="margin-bottom: 15px; color: #67C23A;">计算结果</h4>
                                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                                            <div>
                                                <label style="font-size: 12px; color: #909399;">选择汇率</label>
                                                <div style="font-size: 20px; font-weight: 700; color: #409EFF;">{{ selectedRate || '0.0000' }}</div>
                                            </div>
                                            <div>
                                                <label style="font-size: 12px; color: #909399;">转换金额 (MYR)</label>
                                                <div style="font-size: 20px; font-weight: 700; color: #67C23A;">{{ calculatedAmount.converted_amount || '0.00' }}</div>
                                            </div>
                                            <div style="grid-column: span 2;">
                                                <label style="font-size: 12px; color: #909399;">利润 (P&L)</label>
                                                <div style="font-size: 24px; font-weight: 700; color: #E6A23C;">MYR {{ calculatedAmount.pnl || '0.00' }}</div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label class="form-label">备注</label>
                                        <textarea class="form-control" v-model="transactionForm.remark" rows="3" placeholder="请输入交易备注"></textarea>
                                    </div>
                                    
                                    <div style="display: flex; gap: 12px; margin-top: 30px;">
                                        <button class="btn btn-success" @click="saveTransaction" :disabled="!canSaveTransaction">
                                            <i class="fas fa-save"></i> 保存交易
                                        </button>
                                        <button class="btn btn-danger" @click="resetTransactionForm">
                                            <i class="fas fa-redo"></i> 清空
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 交易记录页面 -->
                    <div v-if="currentPage === 'transactions'">
                        <h1 class="card-title">
                            <i class="fas fa-list"></i> 交易记录
                        </h1>
                        
                        <!-- 筛选条件 -->
                        <div class="card" style="margin-bottom: 20px;">
                            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;">
                                <div>
                                    <label class="form-label">客户</label>
                                    <select class="form-control" v-model="transactionFilter.customer_id">
                                        <option value="">全部客户</option>
                                        <option v-for="customer in allCustomers" :key="customer.id" :value="customer.id">
                                            {{ customer.customer_name }}
                                        </option>
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label">开始日期</label>
                                    <input type="date" class="form-control" v-model="transactionFilter.start_date">
                                </div>
                                <div>
                                    <label class="form-label">结束日期</label>
                                    <input type="date" class="form-control" v-model="transactionFilter.end_date">
                                </div>
                                <div>
                                    <label class="form-label">货币对</label>
                                    <select class="form-control" v-model="transactionFilter.currency_pair">
                                        <option value="">全部</option>
                                        <option value="RMB/MYR">RMB/MYR</option>
                                    </select>
                                </div>
                            </div>
                            <div style="display: flex; gap: 12px; margin-top: 20px;">
                                <button class="btn btn-primary" @click="loadTransactions">
                                    <i class="fas fa-search"></i> 筛选
                                </button>
                                <button class="btn btn-danger" @click="resetTransactionFilter">
                                    <i class="fas fa-redo"></i> 重置
                                </button>
                            </div>
                        </div>
                        
                        <!-- 交易列表 -->
                        <div class="card">
                            <div class="table-container">
                                <table v-if="transactions.length > 0">
                                    <thead>
                                        <tr>
                                            <th>交易日期</th>
                                            <th>客户</th>
                                            <th>源金额 (RMB)</th>
                                            <th>Agent SX Cost</th>
                                            <th>选择汇率</th>
                                            <th>转换金额 (MYR)</th>
                                            <th>利润 (MYR)</th>
                                            <th>操作</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr v-for="transaction in transactions" :key="transaction.id">
                                            <td>{{ formatDate(transaction.transaction_date) }}</td>
                                            <td>{{ transaction.customer.customer_name }} <span v-if="transaction.customer.marking">({{ transaction.customer.marking }})</span></td>
                                            <td>{{ formatCurrency(transaction.source_amount, 'RMB') }}</td>
                                            <td>{{ transaction.agent_sx_cost.toFixed(4) }}</td>
                                            <td>{{ transaction.selected_rate.toFixed(4) }}</td>
                                            <td>{{ formatCurrency(transaction.converted_amount) }}</td>
                                            <td :style="{ color: transaction.pnl >= 0 ? '#67C23A' : '#F56C6C', fontWeight: '700' }">
                                                {{ formatCurrency(transaction.pnl) }}
                                            </td>
                                            <td>
                                                <button class="btn btn-primary" @click="viewTransactionDetail(transaction)">
                                                    <i class="fas fa-eye"></i> 详情
                                                </button>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <div v-else class="empty-state">
                                    <i class="fas fa-exchange-alt"></i>
                                    <p>暂无交易记录</p>
                                </div>
                            </div>
                            
                            <!-- 分页 -->
                            <div class="pagination" v-if="transactionPagination.total > 0">
                                <button class="page-btn" @click="prevTransactionPage" :disabled="transactionPagination.page === 1">
                                    <i class="fas fa-chevron-left"></i>
                                </button>
                                <span>第 {{ transactionPagination.page }} 页 / 共 {{ transactionPagination.pages }} 页</span>
                                <button class="page-btn" @click="nextTransactionPage" :disabled="transactionPagination.page === transactionPagination.pages">
                                    <i class="fas fa-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 月度报表页面 -->
                    <div v-if="currentPage === 'reports'">
                        <h1 class="card-title">
                            <i class="fas fa-chart-bar"></i> 月度报表
                        </h1>
                        
                        <!-- 月份选择 -->
                        <div class="card" style="margin-bottom: 20px;">
                            <div style="display: flex; gap: 12px; align-items: center;">
                                <div>
                                    <label class="form-label">选择年份</label>
                                    <select class="form-control" v-model="reportYear" style="width: 120px;">
                                        <option v-for="year in [2023, 2024, 2025]" :key="year" :value="year">{{ year }}年</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label">选择月份</label>
                                    <select class="form-control" v-model="reportMonth" style="width: 120px;">
